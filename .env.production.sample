# docker compose -f docker-compose.prod.yml build 時にweb(フロント)のビルド引数として使われる。
# NEXT_PUBLIC_*はNext.jsのビルド時にバンドルへ埋め込まれるため、コンテナ起動後には変更できない。
# フェーズ1（ドメイン未取得）: VPSのグローバルIPを指定（ポートは指定しない。nginxが80番で受けて/api/を振り分ける）
# フェーズ2（ドメイン取得後）: https://api.sumaslo-analyzer.dev などに変更してrebuild
NEXT_PUBLIC_API_URL=http://<VPSのIP>
NEXT_PUBLIC_FAVICON_PATH=/favicon-dev.ico
